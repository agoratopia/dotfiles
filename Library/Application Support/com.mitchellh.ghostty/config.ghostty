font-family = Iosevka Nerd Font
font-style = Medium
font-size = 15
theme = Kanagawa Dragon
window-padding-x = 10
window-padding-y = 8

# Global hotkey for a drop-down quick terminal. Requires Accessibility
# permission to be granted to Ghostty (System Settings > Privacy & Security
# > Accessibility) — Ghostty will prompt for this on next launch/reload.
keybind = global:cmd+alt+grave_accent=toggle_quick_terminal
